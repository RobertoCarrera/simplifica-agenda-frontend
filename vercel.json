{
  "buildCommand": "node scripts/generate-environments.mjs && npm run build",
  "outputDirectory": "dist/simplify-agenda-frontend/browser",
  "framework": "angular",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
